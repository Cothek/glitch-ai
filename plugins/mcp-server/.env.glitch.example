; ============================================
; Glitch Credential Vault
; Copy this to .env.glitch and fill in values
; NEVER commit .env.glitch to git
; ============================================

; ── Project: ai-gm ──────────────────────────
[ai-gm]
# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai-gm

# Payment processing
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

; ── Project: ai-gm (production overrides) ───
[ai-gm:production]
DATABASE_URL=postgresql://user:password@prod-host:5432/ai-gm-prod

; ── Project: ecd-website ────────────────────
[ecd-website]
CONTENTFUL_SPACE_ID=your-space-id
CONTENTFUL_ACCESS_TOKEN=your-access-token
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

; ── Named API Services ──────────────────────

; Stripe API
[stripe]
BASE_URL=https://api.stripe.com
AUTH_TYPE=bearer
AUTH_TOKEN=sk_test_xxxxxxxxxxxxxxxxxxxx
DEFAULT_HEADERS={"User-Agent": "Glitch-Connector/1.0"}

; GitHub API
[github]
BASE_URL=https://api.github.com
AUTH_TYPE=bearer
AUTH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

; Generic API with API key in header
[my-custom-api]
BASE_URL=https://api.example.com/v2
AUTH_TYPE=api-key-header
API_KEY_NAME=X-API-Key
API_KEY_VALUE=your-api-key-here
