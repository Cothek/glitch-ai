{
  "$schema": "config/tools-schema.json",
  "description": "External binary tool dependencies for Glitch AI. Launch scripts check this manifest and auto-download missing tools.",
  "tools": [
    {
      "name": "nuclei",
      "description": "Fast vulnerability scanner — automated template-based scanning",
      "homepage": "https://github.com/projectdiscovery/nuclei",
      "binary": "tools/security/nuclei.exe",
      "version": "3.9.0",
      "platforms": {
        "win32": {
          "url": "https://github.com/projectdiscovery/nuclei/releases/download/v{version}/nuclei_{version}_windows_amd64.zip",
          "archive": "zip",
          "extract": ["nuclei.exe"]
        },
        "darwin": {
          "url": "https://github.com/projectdiscovery/nuclei/releases/download/v{version}/nuclei_{version}_darwin_all.zip",
          "archive": "zip",
          "extract": ["nuclei"]
        },
        "linux": {
          "url": "https://github.com/projectdiscovery/nuclei/releases/download/v{version}/nuclei_{version}_linux_amd64.zip",
          "archive": "zip",
          "extract": ["nuclei"]
        }
      }
    },
    {
      "name": "trufflehog",
      "description": "Secret scanner — find leaked credentials in git history and files",
      "homepage": "https://github.com/trufflesecurity/trufflehog",
      "binary": "tools/security/trufflehog.exe",
      "version": "3.95.6",
      "platforms": {
        "win32": {
          "url": "https://github.com/trufflesecurity/trufflehog/releases/download/v{version}/trufflehog_{version}_windows_amd64.tar.gz",
          "archive": "targz",
          "extract": ["trufflehog.exe"]
        },
        "darwin": {
          "url": "https://github.com/trufflesecurity/trufflehog/releases/download/v{version}/trufflehog_{version}_darwin_amd64.tar.gz",
          "archive": "targz",
          "extract": ["trufflehog"]
        },
        "linux": {
          "url": "https://github.com/trufflesecurity/trufflehog/releases/download/v{version}/trufflehog_{version}_linux_amd64.tar.gz",
          "archive": "targz",
          "extract": ["trufflehog"]
        }
      }
    },
    {
      "name": "snyk",
      "description": "Dependency vulnerability scanner for npm projects",
      "homepage": "https://github.com/snyk/snyk",
      "type": "npm",
      "package": "snyk",
      "version": "latest",
      "binary": "snyk"
    }
  ]
}
