{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "glitch-memorycore/prompt-rules.md",
    "glitch-memorycore/CLAUDE.md",
    "glitch-memorycore/master-memory.md",
    "glitch-memorycore/core/identity.md",
    "glitch-memorycore/plugins/glitch-skills/skills-registry.md"
  ],
  "agent": {
    "glitch": {
      "model": "__MODEL__",
      "mode": "primary",
      "description": "Free mode orchestrates tasks using only free models.",
      "color": "#22c55e",
      "temperature": 0.2,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "task": "allow"
      },
      "prompt": "__PROMPT__"
    },
    "glitch-omni": {
      "model": "__MODEL__",
      "mode": "primary",
      "description": "Glitch Omni mode — does all work directly without delegating. Use for quick tasks where delegation overhead isn't worth it.",
      "color": "#22c55e",
      "temperature": 0.2,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "task": "allow"
      }
    },
    "general": {
      "model": "__MODEL__",
      "mode": "subagent",
      "description": "General-purpose agent -- bash, file ops, simple edits, standard code.",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "deny",
        "question": "allow",
        "todowrite": "allow"
      },
      "temperature": 0.2
    },
    "explore": {
      "model": "__MODEL__",
      "mode": "subagent",
      "description": "Codebase research -- find files, search code, answer questions about the codebase. Read-only.",
      "temperature": 0.2
    },
    "plan": {
      "model": "__MODEL__",
      "mode": "subagent",
      "description": "Planning mode -- reason about architecture and designs without executing code.",
      "temperature": 0.2
    },
    "build": {
      "model": "__MODEL__",
      "mode": "subagent",
      "description": "Code scaffolding -- generates code from prompts.",
      "temperature": 0.2
    },
    "coder": {
      "model": "__MODEL__",
      "mode": "subagent",
      "description": "Senior full-stack engineer -- production code, complex logic, server actions, data layers, API routes.",
      "temperature": 0.2
    },
    "ui-designer": {
      "model": "__MODEL__",
      "mode": "subagent",
      "description": "Senior UI designer -- shadcn/ui, Radix, Tailwind v4, visual design, component creation, layout, styling.",
      "temperature": 0.2
    },
    "reviewer": {
      "model": "__MODEL__",
      "mode": "subagent",
      "description": "Independent code quality gate -- read-only, severity-rated reports, security audit.",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "bash": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "deny"
      },
      "temperature": 0.2
    },
    "testing": {
      "model": "__MODEL__",
      "mode": "subagent",
      "description": "Test writer -- TDD, framework detection, edge case coverage, coverage analysis.",
      "temperature": 0.2
    },
    "vision": {
      "model": "__VISION_MODEL__",
      "mode": "subagent",
      "description": "Image and visual content analysis. Analyzes screenshots, UI mockups, diagrams, and other visual content using the read tool.",
      "permission": {
        "read": "allow",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny",
        "edit": "deny"
      },
      "temperature": 0.2
    }
  },
  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 2000,
      "max_height": 2000,
      "max_base64_bytes": 5242880
    }
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "server": {
    "port": 4100,
    "hostname": "0.0.0.0"
  },
  "default_agent": "glitch",
  "compaction": {
    "auto": true,
    "tail_turns": 8
  }
}
