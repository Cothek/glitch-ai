{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "glitch-memorycore/prompt-rules.md",
    "glitch-memorycore/CLAUDE.md",
    "glitch-memorycore/main/current-session.md",
    "glitch-memorycore/main/main-memory.md",
    "glitch-memorycore/main/reminders.md",
    "glitch-memorycore/main/session-dashboard.md"
  ],
  "agent": {
    "vision": {
      "model": "opencode-go/qwen3.6-plus",
      "mode": "subagent",
      "description": "Analyzes images, screenshots, and visual output. Use when reviewing UI layouts, checking browser screenshots, debugging visual issues, or any task requiring visual analysis of images. Only use when image input is needed.",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "bash": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "deny"
      },
      "temperature": 0.2
    },
    "coder": {
      "model": "opencode-go/qwen3.6-plus",
      "mode": "subagent",
      "description": "Complex code generation and architecture work ($0.50/$3.00). Use when tasks involve 5+ files, authentication, data flow, API integration, database schemas, or any work requiring strong reasoning. Falls back from @general when free model is insufficient for complex code.",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "deny",
        "question": "allow",
        "todowrite": "allow"
      },
      "temperature": 0.2
    },
    "general-paid": {
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent",
      "description": "Same as @general but uses paid deepseek-v4-flash ($0.14/$0.28, 1M context). Use ONLY as fallback when @general's free model hits quota limits. NOT for routine use.",
      "hidden": true,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "deny",
        "question": "allow",
        "todowrite": "allow"
      },
      "temperature": 0.2
    }
  },
  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 2000,
      "max_height": 2000,
      "max_base64_bytes": 5242880
    }
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "server": {
    "port": 4100,
    "hostname": "0.0.0.0"
  },
  "default_agent": "delegator",
  "compaction": {
    "auto": true,
    "tail_turns": 8
  }
}
